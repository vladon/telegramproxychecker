# Delegates to Makefile for the Linux x86_64 release matrix.

release-all:
    make release-all

build-gnu:
    make build-gnu

build-musl:
    make build-musl

build-gnu-v3:
    make build-gnu-v3

build-musl-v3:
    make build-musl-v3

build-musl-static:
    make build-musl-static

build-musl-v3-static:
    make build-musl-v3-static
